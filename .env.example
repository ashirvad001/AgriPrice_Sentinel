# ═══════════════════════════════════════════════════════════════════════════════
#  AgriPrice Sentinel — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mandi_db

# ── Redis (caching & Celery broker) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication (REQUIRED) ───────────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
# Must be at least 32 characters long.
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# ── Twilio (WhatsApp alerts) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TEMPLATE_SID=  # Twilio content template SID (e.g. HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)

# ── Agmarknet / data.gov.in (price scraper) ──────────────────────────────────
# Get a free API key at: https://data.gov.in/
DATAGOV_API_KEY=

# ── OpenWeatherMap (weather scraper) ─────────────────────────────────────────
# Get a free API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── MLflow (model tracking & registry) ───────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# ── Slack (optional — alert notifications) ───────────────────────────────────
SLACK_WEBHOOK_URL=
